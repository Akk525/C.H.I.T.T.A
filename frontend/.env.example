# ── Mapbox ────────────────────────────────────────────────────────────────────
# Required for the interactive map. Get a free token at https://mapbox.com.
# Without this, the map shows a plain placeholder — all other features work.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_token_here

# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL for the CHITTA FastAPI backend. Change to your deployed URL in prod.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── API Security ──────────────────────────────────────────────────────────────
# Must match CHITTA_API_KEY set in the backend .env.
# Sent as X-Api-Key header on every backend request.
# This is a shared demo key — not per-user authentication.
# Leave blank to run without auth in local dev (backend must also have no key set).
NEXT_PUBLIC_CHITTA_API_KEY=

