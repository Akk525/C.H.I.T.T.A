# ── API Security ──────────────────────────────────────────────────────────────
# Shared API key for demo-level access control.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Leave blank to run unauthenticated (local dev only — not safe for production).
CHITTA_API_KEY=

# Maximum request body size in bytes (default 2 MB).
CHITTA_MAX_BODY_BYTES=2097152

# Maximum serialised size of the payload field in /api/history/save (default 1 MB).
CHITTA_MAX_HISTORY_PAYLOAD_BYTES=1048576

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Required only for history features (Run History,
# LangGraph comparison). Set PERSIST_ANALYSES=false to disable without a DB.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/chitta

# Set to true to activate run persistence. Requires DATABASE_URL to be reachable.
PERSIST_ANALYSES=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Add your frontend URL in production.
CORS_ORIGINS=http://localhost:3000

# ── AI Synthesis ──────────────────────────────────────────────────────────────
# LLM provider for AI briefing narratives. "mock" works without any API key.
# Options: mock | claude | gemini | openai
CHITTA_LLM_PROVIDER=mock

# API keys (set the one matching CHITTA_LLM_PROVIDER)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# GEMINI_API_KEY=              # alias for GOOGLE_API_KEY
OPENAI_API_KEY=

# Model name for synthesis (provider-specific default if unset):
#   claude → claude-sonnet-4-20250514
#   gemini → gemini-2.5-flash (or gemini-3.5-flash)
#   openai → gpt-4.1-mini
CHITTA_SYNTHESIS_MODEL=

# ── Development Signals ───────────────────────────────────────────────────────
# GDELT news signals provider. "mock" returns deterministic signals offline.
# "gdelt" queries the live GDELT DOC API (rate-limited to 1 req/5s, free).
# Options: mock | gdelt
CHITTA_SIGNALS_PROVIDER=mock

